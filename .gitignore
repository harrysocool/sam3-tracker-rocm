__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Model weights and ONNX files (download/generate separately)
# model weights (download separately)
model/**/*.safetensors
model/**/*.pt
model/**/*.bin
onnx_files/
onnx_files_1008/

# Datasets
dataset/

# Results and outputs
results/
# outputs/ — ignore contents but keep the (empty) dir so demo.py default works
outputs/*
!outputs/.gitkeep

# Big media generated by demo / probes
*.mp4
*.jpg
*.gif
*_tracked.*
*_demo.*
# Whitelist source images (assets/) and committed doc visuals (docs/images/)
!assets/*.jpg
!docs/images/*.jpg
!docs/images/*.gif
!docs/images/*.mp4

# TunableOp cache
tunableop_results*.csv

# MIGraphX cache
/tmp/migraphx/
*.mxr

# IDE
.vscode/
.idea/

# Local mxr cache (legacy 3-session compile artifacts)
mxr_cache/
