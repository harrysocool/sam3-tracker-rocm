__pycache__/
*.py[cod]
*.egg-info/
.eggs/

# Model weights and ONNX artefacts (downloaded / generated separately)
model/
onnx_files_504/
onnx_files_1008/

# Datasets
dataset/

# Results: ignore generated artefacts; whitelist what should be committed.
# Subdirs:
#   results/eval/{davis,saco_sg}/  — JSON eval outputs (whitelisted below)
#   results/correctness/           — MIG-vs-PT visuals (whitelisted below)
#   results/probes/                — probe outputs (gitignored, .gitkeep only)
#   results/archive/               — historical demo media (whitelisted below)
results/**
!results/eval/
!results/eval/davis/
!results/eval/davis/*.json
!results/eval/saco_sg/
!results/eval/saco_sg/baseline_*_v2.json
!results/eval/saco_sg/saco_sg_*_eval_res.json
!results/eval/saco_sg/saco_sg_*_eval_res2.json
!results/correctness/
!results/correctness/*.jpg
!results/probes/
!results/probes/.gitkeep
!results/archive/
!results/archive/*.jpg
!results/archive/*.mp4
!results/archive/*.json

# analysis/ — working research notes; ignore new files, keep the 4 historically tracked docs
analysis/**
!analysis/backbone_optimization.md
!analysis/backbone_optimization_research.md
!analysis/migraphx_backbone_investigation.md
!analysis/module_optimization.md

# demo_out/ — ignore contents but keep subdir scaffolding for demo defaults
demo_out/**
!demo_out/.gitkeep
!demo_out/box/
!demo_out/box/.gitkeep
!demo_out/text/
!demo_out/text/.gitkeep
!demo_out/probes/
!demo_out/probes/.gitkeep

# Big generated media (catch-all). Whitelisted source / docs / archive below.
*.mp4
*.jpg
*.gif
*_tracked.*
*_demo.*
!assets/*.jpg
!assets/*.mp4
!docs/images/*.jpg
!docs/images/*.gif
!docs/images/*.mp4
!results/correctness/*.jpg
!results/archive/*.jpg
!results/archive/*.mp4

